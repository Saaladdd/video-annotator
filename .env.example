# Copy this file to .env and fill in whichever key(s) you use.
# The .env file is auto-loaded at startup.

# OpenAI (and any OpenAI-compatible provider that reads OPENAI_API_KEY)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# HuggingFace (only needed if downloading gated/private models)
HF_TOKEN=
